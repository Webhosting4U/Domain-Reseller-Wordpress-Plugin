{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wh4u/domain-lookup",
	"version": "1.1.0",
	"title": "Domain Lookup",
	"category": "widgets",
	"icon": "admin-site-alt3",
	"description": "A domain availability search form powered by WH4U Domains.",
	"keywords": [ "domain", "search", "lookup", "availability", "whois", "register" ],
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"color": {
			"text": true,
			"background": true,
			"link": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true
		},
		"spacing": {
			"padding": true,
			"margin": true
		}
	},
	"textdomain": "wh4u-domains",
	"attributes": {
		"placeholder": {
			"type": "string"
		},
		"buttonText": {
			"type": "string"
		},
		"accentColor": {
			"type": "string"
		},
		"styleVariant": {
			"type": "string",
			"enum": [ "elevated", "flat", "bordered", "minimal" ]
		},
		"showSuggestions": {
			"type": "boolean"
		},
		"formTitle": {
			"type": "string"
		},
		"formDescription": {
			"type": "string"
		},
		"borderRadius": {
			"type": "string"
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./editor.css"
}
